                        {p.description}
                      </p>

                      {/* ── Seller info block ── */}
                      {p.seller && (
                        <div className="d-flex align-items-center gap-2 mb-2 p-2 rounded-2" style={{ background: '#f8f9fa' }}>
                          <img
                            src={resolveImage(p.seller.avatarUrl)}
